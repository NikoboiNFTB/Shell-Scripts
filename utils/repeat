#!/usr/bin/env bash

set -e

# Check if at least 2 arguments are given
if [ "$#" -lt 2 ]; then
  echo "Usage:"
  echo "	$0 <command_in_quotes> <interval_in_seconds>"
  echo "	or"
  echo "	$0 <interval_in_seconds> <command_in_quotes>"
  echo "Example: $0 \"ls -1\" 5"
  exit 1
fi

# Determine which argument is the interval (a number)
if [[ "$1" =~ ^[0-9]+$ ]]; then
  INTERVAL="$1"
  CMD="${@:2}"  # All remaining args as the command
elif [[ "$2" =~ ^[0-9]+$ ]]; then
  INTERVAL="$2"
  CMD="$1"
else
  echo "Error: could not detect interval as a number."
  exit 1
fi

echo "Running command: $CMD every $INTERVAL second(s)..."
echo "Press Ctrl+C to stop."

# Infinite loop to run the command
while true; do
  eval "$CMD"
  sleep "$INTERVAL"
done
