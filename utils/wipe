#!/usr/bin/env bash

set -euo pipefail

# Collect users from /home
mapfile -t USERS < <(ls -1 /home)

# Ensure we found users
if [[ ${#USERS[@]} -eq 0 ]]; then
	echo "No users found in /home"
	exit 1
fi

# Show menu
echo "Select a user:"
for i in "${!USERS[@]}"; do
	printf "%d) %s\n" "$((i + 1))" "${USERS[$i]}"
done

# Read selection
read -rp "Enter number: " choice

# Validate input
if ! [[ "$choice" =~ ^[0-9]+$ ]] || ((choice < 1 || choice > ${#USERS[@]})); then
	echo "Invalid selection"
	exit 1
fi

# Resolve user + home
USER="${USERS[$((choice - 1))]}"
USER_HOME="/home/$USER"

# Final sanity check
if [[ ! -d "$USER_HOME" ]]; then
	echo "Home directory does not exist: $USER_HOME"
	exit 1
fi

echo "Selected user: $USER"
echo "Home directory: $USER_HOME"

BIN="/usr/local/bin"
GITUSER="NikoboiNFTB"

# Ensure base directory exists
mkdir -p "$USER_HOME/GitHub/$GITUSER"

# Function: confirm deletion (default yes)
confirm_delete() {
	local target="$1"
	read -rp "Delete $target? [Y/n]: " answer
	answer=${answer:-Y}

	if [[ "$answer" =~ ^[Yy]$ ]]; then
		rm -rf "$target"
		echo "Deleted: $target"
	else
		echo "Skipped: $target"
	fi
}

# Clean up
for file in \
	"$USER_HOME/.ssh/id_ed25519_github" \
	"$USER_HOME/.ssh/id_ed25519_github.pub" \
	"$USER_HOME/GitHub" \
	"$BIN/bcd" \
	"$BIN/bcp" \
	"$BIN/bmv" \
	"$BIN/cat-dir" \
	"$BIN/find-file" \
	"$BIN/find-string" \
	"$BIN/git-automation" \
	"$BIN/git-workflow" \
	"$BIN/repeat"; do

	confirm_delete "$file"
done

# Clone repos
for repo in GitHub-Tools Shell-Scripts; do
	dest="$USER_HOME/GitHub/$GITUSER/$repo"

	if [[ -d "$dest" ]]; then
		confirm_delete "$dest"
	fi

	git clone "https://github.com/$GITUSER/$repo" "$dest"
done

echo "Done."
